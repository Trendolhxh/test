{
  "description": "Agent 层评测用例：验证 LLM 在各场景下的工具调用和回复质量",
  "version": "1.0",
  "evaluation_method": "每个 case 包含 input（构造 API 请求所需的全部信息）和 expected_behaviors（可检查的行为断言列表）",
  "fixtures": {
    "profiles": {
      "typical": "user-profiles/typical-night-owl.md",
      "new_user": "user-profiles/new-user.md"
    },
    "plans": {
      "phone": "intervention-plans/phone-intervention.md",
      "empty": "intervention-plans/empty.md"
    }
  },

  "cases": [
    {
      "id": "agent-01",
      "name": "模式1-纯对话：用户吐槽加班，不引导到睡眠",
      "category": "pure_conversation",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "今天加班好累"}
        ]
      },
      "expected_behaviors": [
        {"type": "no_tool_call", "tool": "get_health_data", "reason": "用户在吐槽，不是在问数据"},
        {"type": "no_tool_call", "tool": "send_feedback_card", "reason": "不是建议场景"},
        {"type": "response_length", "max_sentences": 3},
        {"type": "response_tone", "must_not_contain_patterns": ["建议你", "您应该", "根据数据"], "reason": "不说教、不给未被要求的建议"},
        {"type": "response_tone", "should_express": "empathy", "reason": "共情，追问细节"}
      ]
    },
    {
      "id": "agent-02",
      "name": "模式2-查数据：用户问最近睡得怎么样",
      "category": "query_data",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "我最近睡得怎么样？"}
        ]
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "show_status", "reason": "查数据前先显示进度"},
        {"type": "tool_called", "tool": "get_health_data", "params_contain": {"metrics": ["sleep_stages"], "date_range": "7d"}, "reason": "查最近睡眠数据"},
        {"type": "response_has_anchored_numbers", "reason": "数字要有对比锚点（和上周比、和正常范围比）"},
        {"type": "response_length", "min_sentences": 2, "max_sentences": 5},
        {"type": "tool_called", "tool": "suggest_replies", "reason": "提供快捷回复降低门槛"}
      ]
    },
    {
      "id": "agent-03",
      "name": "模式3-记录信息：用户透露换了遮光窗帘",
      "category": "save_memory",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "我最近换了个遮光窗帘"}
        ]
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "save_memory", "params_contain": {"category": "life_detail"}, "reason": "记录生活细节"},
        {"type": "response_must_not_contain", "patterns": ["记下了", "记录了", "已保存", "noted"], "reason": "save_memory 是静默操作"},
        {"type": "response_tone", "should_express": "natural_follow_up", "reason": "自然地追问效果"}
      ]
    },
    {
      "id": "agent-04",
      "name": "模式4-建议+反馈卡：agent 主动给行动建议",
      "category": "advice_with_feedback",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "我想改善一下睡眠，有什么建议吗？"}
        ]
      },
      "expected_behaviors": [
        {"type": "response_single_advice", "reason": "一次只给一个行动建议，不列清单"},
        {"type": "advice_is_actionable", "reason": "建议必须是具体动作，不是"早点睡""},
        {"type": "advice_respects_redlines", "redlines": ["限制咖啡", "早起运动"], "reason": "不能建议红线中的内容"},
        {"type": "tool_called", "tool": "set_reminder", "reason": "配合建议设置提醒"},
        {"type": "tool_called", "tool": "send_feedback_card", "reason": "安排反馈收集"},
        {"type": "tool_called", "tool": "suggest_replies", "reason": "提供快捷回复"}
      ]
    },
    {
      "id": "agent-05",
      "name": "模式5-数据+图表：用户要看睡眠趋势",
      "category": "data_with_chart",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "给我看看这周的睡眠趋势"}
        ]
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "get_health_data", "params_contain": {"metrics": ["sleep_stages"], "date_range": "7d"}},
        {"type": "tool_called", "tool": "render_analysis_card", "params_should_have": ["title", "chart", "summary"]},
        {"type": "response_length", "max_sentences": 3, "reason": "详细内容在卡片内，文字部分简短"}
      ]
    },

    {
      "id": "agent-06",
      "name": "场景指令-新睡眠数据：早上打开App看到昨晚数据",
      "category": "scene_new_sleep_data",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": "## 当前场景\n\n用户今天第一次打开 App。以下是昨晚的睡眠数据摘要：\n入睡 01:30，起床 08:15，总睡眠 6h45m，深睡 18%，REM 25%，睡眠债 1.5h\n\n像朋友一样聊昨晚的睡眠，不要像报告一样列数据。\n如果数据和干预策略中的当前干预相关，可以关联起来聊。",
        "messages": []
      },
      "expected_behaviors": [
        {"type": "response_tone", "must_not_contain_patterns": ["根据数据", "数据显示", "分析结果"], "reason": "像朋友聊天，不像报告"},
        {"type": "response_relates_to_intervention", "reason": "应关联当前干预（手机放客厅）聊"},
        {"type": "response_length", "min_sentences": 2, "max_sentences": 4},
        {"type": "tool_called", "tool": "suggest_replies", "reason": "给用户快捷回复选项"}
      ]
    },
    {
      "id": "agent-07",
      "name": "场景指令-反馈卡提交：用户反馈做到了",
      "category": "scene_feedback_positive",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": "## 当前场景\n\n用户刚提交了一张反馈卡：\n- 关联建议：每晚 11 点闹钟响后把手机放到客厅\n- 用户选择：做到了\n- 用户补充：感觉确实比平时早睡了半小时\n\n基于反馈推进对话：\n- 做到了 → 具体肯定，考虑固化或推进下一步",
        "messages": []
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "save_memory", "params_contain": {"category": "intervention_feedback"}, "reason": "记录干预反馈"},
        {"type": "response_specific_praise", "reason": "具体肯定做到的部分，不空泛鼓励"},
        {"type": "response_considers_next_step", "reason": "考虑固化或推进下一步"},
        {"type": "tool_called", "tool": "suggest_replies"}
      ]
    },
    {
      "id": "agent-08",
      "name": "场景指令-反馈卡提交：用户反馈没做到",
      "category": "scene_feedback_negative",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": "## 当前场景\n\n用户刚提交了一张反馈卡：\n- 关联建议：每晚 11 点闹钟响后把手机放到客厅\n- 用户选择：没做到\n- 用户补充：加班到 11 点多，实在太累了\n\n基于反馈推进对话：\n- 没做到 → 理解原因，考虑调整方法或降低难度",
        "messages": []
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "save_memory", "params_contain": {"category": "intervention_feedback"}},
        {"type": "response_tone", "must_not_contain_patterns": ["你应该", "你需要", "必须", "一定要"], "reason": "不追责"},
        {"type": "response_understands_reason", "reason": "理解加班导致无法执行的原因"},
        {"type": "response_adjusts_approach", "reason": "应提出调整方案（如加班日降低目标）"},
        {"type": "tool_called", "tool": "suggest_replies"}
      ]
    },
    {
      "id": "agent-09",
      "name": "场景指令-推送点击：用户点了放手机提醒",
      "category": "scene_push_click",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": "## 当前场景\n\n用户点击了一条提醒推送进入 App：\n- 提醒内容：该放下手机了，把它放到客厅充电吧\n- 关联干预：减少睡前手机使用\n\n顺着提醒的上下文和用户聊。如果用户接着说了别的话题，跟随用户。",
        "messages": []
      },
      "expected_behaviors": [
        {"type": "response_follows_reminder_context", "reason": "顺着提醒内容自然开口"},
        {"type": "response_length", "max_sentences": 2, "reason": "简短鼓励即可"},
        {"type": "response_tone", "must_not_contain_patterns": ["根据你的干预计划"], "reason": "不暴露系统机制"},
        {"type": "tool_called", "tool": "suggest_replies"}
      ]
    },
    {
      "id": "agent-10",
      "name": "场景指令-子agent洞察：深睡持续改善",
      "category": "scene_agent_insight",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": "## 当前场景\n\n以下是最近发现的一个值得关注的变化：\n手机放客厅干预连续 3 天执行，深睡占比从 16% 稳定提升到 20%，入睡时间平均提前 40 分钟。\n\n用你自己的话和用户聊这个发现。不要说"系统检测到"。",
        "messages": []
      },
      "expected_behaviors": [
        {"type": "response_must_not_contain", "patterns": ["系统检测到", "数据分析显示", "我们发现"], "reason": "不暴露系统机制"},
        {"type": "response_naturally_shares_insight", "reason": "用朋友口吻分享发现"},
        {"type": "response_has_anchored_numbers", "reason": "数字要有对比锚点"},
        {"type": "tool_called", "tool": "suggest_replies"}
      ]
    },

    {
      "id": "agent-11",
      "name": "红线测试：用户问要不要少喝咖啡",
      "category": "redline",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "是不是下午少喝咖啡会睡得好一些？"}
        ]
      },
      "expected_behaviors": [
        {"type": "response_must_not_suggest", "suggestion": "限制咖啡", "reason": "咖啡是红线，用户画像明确标注"},
        {"type": "response_respects_user_need", "reason": "应承认用户对咖啡的需求，不直接否定"},
        {"type": "no_tool_call", "tool": "set_reminder", "reason": "不应该设置限制咖啡的提醒"}
      ]
    },
    {
      "id": "agent-12",
      "name": "红线测试：agent不应主动建议早起运动",
      "category": "redline",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "有没有什么办法让我精力好一些？"}
        ]
      },
      "expected_behaviors": [
        {"type": "response_must_not_suggest", "suggestion": "早起运动", "reason": "早起运动是红线"},
        {"type": "response_must_not_suggest", "suggestion": "限制咖啡", "reason": "限制咖啡是红线"},
        {"type": "advice_is_actionable", "reason": "给出红线以外的可行建议"}
      ]
    },

    {
      "id": "agent-13",
      "name": "新用户首次对话：画像为空",
      "category": "new_user",
      "input": {
        "profile": "new_user",
        "plan": "empty",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "你好"}
        ]
      },
      "expected_behaviors": [
        {"type": "response_asks_questions", "reason": "画像为空时应主动了解用户"},
        {"type": "no_tool_call", "tool": "get_health_data", "reason": "还不了解用户，不应直接查数据"},
        {"type": "no_tool_call", "tool": "send_feedback_card", "reason": "还没给过建议，不应发反馈卡"},
        {"type": "response_tone", "should_express": "warm_welcome", "reason": "友好的开场"}
      ]
    },
    {
      "id": "agent-14",
      "name": "新用户首次对话：用户主动描述问题",
      "category": "new_user",
      "input": {
        "profile": "new_user",
        "plan": "empty",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "我最近老是失眠，晚上怎么都睡不着"}
        ]
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "save_memory", "params_contain": {"category": "sleep_feedback"}, "reason": "记录用户反馈的睡眠问题"},
        {"type": "response_asks_follow_up", "reason": "追问细节（入睡困难的具体情况）而非直接给建议"},
        {"type": "response_tone", "should_express": "empathy"},
        {"type": "no_tool_call", "tool": "send_feedback_card", "reason": "还不了解用户，不应急于给建议和反馈卡"}
      ]
    },

    {
      "id": "agent-15",
      "name": "多轮对话：用户先聊别的再问睡眠",
      "category": "multi_turn",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "今天下午开了个好无聊的会"},
          {"role": "assistant", "content": "哈，多长时间？"},
          {"role": "user", "content": "两个小时！说的全是废话。对了，我昨晚好像睡得还行？"}
        ]
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "get_health_data", "reason": "用户问了昨晚睡眠，应查数据"},
        {"type": "response_addresses_both_topics", "reason": "可以简短回应会议，然后转到睡眠数据"}
      ]
    },
    {
      "id": "agent-16",
      "name": "用户拒绝当前建议：应尊重并调整",
      "category": "user_rejection",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "手机放客厅太不方便了，我用手机当闹钟的"}
        ]
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "save_memory", "params_contain": {"category": "preference"}, "reason": "记录用户拒绝原因"},
        {"type": "response_respects_rejection", "reason": "不坚持让用户继续放手机"},
        {"type": "response_offers_alternative", "reason": "应提出替代方案（如买个闹钟、用定时锁屏等）"},
        {"type": "response_tone", "must_not_contain_patterns": ["但是你应该", "你可以试试坚持"], "reason": "不否定用户的理由"}
      ]
    },
    {
      "id": "agent-17",
      "name": "加班日特殊场景：降低期望",
      "category": "workday_special",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": "## 当前场景\n\n用户今天第一次打开 App。以下是昨晚的睡眠数据摘要：\n入睡 02:15，起床 08:45，总睡眠 6h30m，深睡 14%，REM 22%\n备注：昨天是周三（固定加班日）\n\n像朋友一样聊昨晚的睡眠，不要像报告一样列数据。\n如果数据和干预策略中的当前干预相关，可以关联起来聊。",
        "messages": []
      },
      "expected_behaviors": [
        {"type": "response_acknowledges_context", "context": "加班日", "reason": "应识别周三加班日，理解数据偏差"},
        {"type": "response_tone", "must_not_contain_patterns": ["你昨晚又熬夜了", "你应该"], "reason": "加班日不追责"},
        {"type": "response_length", "max_sentences": 3}
      ]
    },
    {
      "id": "agent-18",
      "name": "工具报错：get_health_data 失败后的降级处理",
      "category": "error_handling",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "我最近睡得怎么样？"},
          {"role": "assistant", "content": null, "tool_calls": [{"name": "get_health_data", "arguments": {"metrics": ["sleep_stages"], "date_range": "7d"}}]},
          {"role": "tool", "content": "{\"error\": \"health_data_service_unavailable\", \"message\": \"无法连接健康数据服务，请稍后重试\"}"}
        ]
      },
      "expected_behaviors": [
        {"type": "response_handles_error_gracefully", "reason": "不卡住，向用户说明情况"},
        {"type": "response_must_not_contain", "patterns": ["health_data_service_unavailable", "error"], "reason": "不暴露技术错误详情"},
        {"type": "response_offers_fallback", "reason": "可以基于画像中已有的信息回答，或建议稍后再看"}
      ]
    },

    {
      "id": "agent-19",
      "name": "样式检查：用户风格活泼时可跟随 emoji",
      "category": "style_adaptation",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "昨晚居然 12 点就睡了哈哈哈 😆 太难得了！"},
          {"role": "assistant", "content": "哈哈真的假的？比平时早了一个多小时啊。昨晚做了什么不一样的吗？"},
          {"role": "user", "content": "手机放客厅了嘿嘿 📱→🛋️ 效果拔群！"}
        ]
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "save_memory", "params_contain": {"category": "intervention_feedback"}},
        {"type": "response_tone", "may_use_emoji": true, "reason": "用户风格活泼，可以适度跟随"},
        {"type": "response_specific_praise", "reason": "具体肯定手机放客厅的效果"}
      ]
    },
    {
      "id": "agent-20",
      "name": "样式检查：不使用 markdown 格式",
      "category": "style_format",
      "input": {
        "profile": "typical",
        "plan": "phone",
        "scene_instruction": null,
        "messages": [
          {"role": "user", "content": "帮我总结一下这周的睡眠情况"}
        ]
      },
      "expected_behaviors": [
        {"type": "tool_called", "tool": "get_health_data"},
        {"type": "response_format", "must_not_contain_patterns": ["^##", "^- ", "^\\d+\\.", "**"], "reason": "移动端不使用 markdown 格式"},
        {"type": "response_format", "is_plain_text": true}
      ]
    }
  ]
}
