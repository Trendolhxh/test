{
  "description": "状态机层评测用例：EventContext → INVOKE/SILENT 判定",
  "version": "1.0",
  "cases": [
    {
      "id": "sm-01",
      "name": "用户主动发消息 → 一律 INVOKE",
      "input": {
        "event_type": "user_message",
        "timestamp": "2026-03-25T21:30:00+08:00",
        "minutes_since_last_conversation": 120,
        "last_conversation_initiator": "user",
        "last_conversation_user_replied": true,
        "has_pending_insight": false,
        "has_unseen_sleep_data": false
      },
      "expected": {
        "decision": "INVOKE",
        "scene": null
      },
      "note": "用户主动行为，不检查任何条件"
    },
    {
      "id": "sm-02",
      "name": "反馈卡提交 → 一律 INVOKE + 注入反馈数据",
      "input": {
        "event_type": "feedback_submit",
        "timestamp": "2026-03-26T08:15:00+08:00",
        "minutes_since_last_conversation": 600,
        "last_conversation_initiator": "agent",
        "last_conversation_user_replied": false,
        "has_pending_insight": false,
        "has_unseen_sleep_data": true,
        "feedback_data": {
          "suggestion_id": "sug_001",
          "suggestion_description": "每晚 11 点闹钟响后把手机放到客厅",
          "completion_value": "yes",
          "follow_up_text": "但 11 点有点早，12 点更现实"
        }
      },
      "expected": {
        "decision": "INVOKE",
        "scene": "feedback_submit",
        "scene_data_contains": ["suggestion_description", "completion_value", "follow_up_text"]
      },
      "note": "即使 agent 上次说了用户没回，反馈提交也一律 INVOKE"
    },
    {
      "id": "sm-03",
      "name": "推送点击 → 一律 INVOKE + 注入提醒上下文",
      "input": {
        "event_type": "push_click",
        "timestamp": "2026-03-25T23:00:00+08:00",
        "minutes_since_last_conversation": 180,
        "last_conversation_initiator": "agent",
        "last_conversation_user_replied": false,
        "has_pending_insight": false,
        "has_unseen_sleep_data": false,
        "reminder_data": {
          "reminder_message": "该放下手机了，把它放到客厅充电吧",
          "intervention_description": "减少睡前手机使用"
        }
      },
      "expected": {
        "decision": "INVOKE",
        "scene": "push_click",
        "scene_data_contains": ["reminder_message", "intervention_description"]
      },
      "note": "用户主动点击推送，不检查任何条件"
    },
    {
      "id": "sm-04",
      "name": "app_open + agent上次说了用户没回 → SILENT",
      "input": {
        "event_type": "app_open",
        "timestamp": "2026-03-25T14:00:00+08:00",
        "minutes_since_last_conversation": 60,
        "last_conversation_initiator": "agent",
        "last_conversation_user_replied": false,
        "has_pending_insight": false,
        "has_unseen_sleep_data": true
      },
      "expected": {
        "decision": "SILENT",
        "scene": null
      },
      "note": "即使有未看睡眠数据，agent 上次说了用户没回就不追"
    },
    {
      "id": "sm-05",
      "name": "app_open + 30分钟内 + 无紧急洞察 → SILENT",
      "input": {
        "event_type": "app_open",
        "timestamp": "2026-03-25T09:30:00+08:00",
        "minutes_since_last_conversation": 15,
        "last_conversation_initiator": "user",
        "last_conversation_user_replied": true,
        "has_pending_insight": false,
        "has_unseen_sleep_data": true
      },
      "expected": {
        "decision": "SILENT",
        "scene": null
      },
      "note": "30分钟冷却期内，即使有未看数据也不打扰"
    },
    {
      "id": "sm-06",
      "name": "app_open + 30分钟内 + 有紧急洞察 → INVOKE（洞察覆盖冷却）",
      "input": {
        "event_type": "app_open",
        "timestamp": "2026-03-25T09:30:00+08:00",
        "minutes_since_last_conversation": 15,
        "last_conversation_initiator": "user",
        "last_conversation_user_replied": true,
        "has_pending_insight": true,
        "has_unseen_sleep_data": true,
        "insight_data": {
          "insight_description": "连续 5 天深睡占比低于 15%，且与睡前屏幕时间强相关"
        }
      },
      "expected": {
        "decision": "INVOKE",
        "scene": "agent_insight",
        "scene_data_contains": ["insight_description"]
      },
      "note": "紧急洞察可以覆盖 30 分钟冷却期"
    },
    {
      "id": "sm-07",
      "name": "app_open + 有待推送洞察（优先于睡眠数据）→ INVOKE",
      "input": {
        "event_type": "app_open",
        "timestamp": "2026-03-25T09:00:00+08:00",
        "minutes_since_last_conversation": 480,
        "last_conversation_initiator": "user",
        "last_conversation_user_replied": true,
        "has_pending_insight": true,
        "has_unseen_sleep_data": true,
        "insight_data": {
          "insight_description": "手机放客厅干预连续3天执行，深睡占比从16%稳定提升到20%"
        }
      },
      "expected": {
        "decision": "INVOKE",
        "scene": "agent_insight",
        "scene_data_contains": ["insight_description"]
      },
      "note": "洞察优先级高于睡眠数据，只注入一个场景"
    },
    {
      "id": "sm-08",
      "name": "app_open + 有未看睡眠数据（无洞察）→ INVOKE",
      "input": {
        "event_type": "app_open",
        "timestamp": "2026-03-25T08:30:00+08:00",
        "minutes_since_last_conversation": 480,
        "last_conversation_initiator": "user",
        "last_conversation_user_replied": true,
        "has_pending_insight": false,
        "has_unseen_sleep_data": true,
        "sleep_summary": {
          "bedtime": "01:30",
          "wake_time": "08:15",
          "total_minutes": 405,
          "deep_percent": 18,
          "sleep_debt_hours": 1.5
        }
      },
      "expected": {
        "decision": "INVOKE",
        "scene": "new_sleep_data",
        "scene_data_contains": ["bedtime", "wake_time", "deep_percent"]
      },
      "note": "今天第一次打开 App，昨晚数据已同步"
    },
    {
      "id": "sm-09",
      "name": "app_open + 什么都没有 → SILENT",
      "input": {
        "event_type": "app_open",
        "timestamp": "2026-03-25T15:00:00+08:00",
        "minutes_since_last_conversation": 120,
        "last_conversation_initiator": "user",
        "last_conversation_user_replied": true,
        "has_pending_insight": false,
        "has_unseen_sleep_data": false
      },
      "expected": {
        "decision": "SILENT",
        "scene": null
      },
      "note": "没有任何待处理事项，不打扰"
    },
    {
      "id": "sm-10",
      "name": "app_open + agent上次说了用户回了 + 有洞察 → INVOKE",
      "input": {
        "event_type": "app_open",
        "timestamp": "2026-03-25T20:00:00+08:00",
        "minutes_since_last_conversation": 300,
        "last_conversation_initiator": "agent",
        "last_conversation_user_replied": true,
        "has_pending_insight": true,
        "has_unseen_sleep_data": false,
        "insight_data": {
          "insight_description": "用户近3天步数下降50%，可能影响睡眠质量"
        }
      },
      "expected": {
        "decision": "INVOKE",
        "scene": "agent_insight",
        "scene_data_contains": ["insight_description"]
      },
      "note": "agent 上次说了但用户有回复，不触发沉默规则"
    }
  ]
}
