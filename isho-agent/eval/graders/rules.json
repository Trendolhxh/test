{
  "global_rules": {
    "blacklist_phrases": {
      "description": "任何 case 的回复都不应包含这些短语",
      "phrases": [
        "系统检测到",
        "根据数据分析",
        "数据显示",
        "根据您的数据",
        "作为AI",
        "作为人工智能",
        "我是一个AI",
        "根据分析结果"
      ],
      "severity": "hard_fail"
    },
    "no_markdown_formatting": {
      "description": "回复中不应出现 markdown 格式（标题、加粗、列表符号）",
      "patterns": ["^#{1,3} ", "\\*\\*[^*]+\\*\\*", "^- ", "^\\d+\\. "],
      "severity": "soft_fail"
    }
  },

  "shared_phrase_sets": {
    "redline_coffee": ["少喝咖啡", "限制咖啡", "减少咖啡", "戒咖啡", "不喝咖啡", "咖啡因摄入"],
    "lecturing_tone": ["你应该", "必须", "你不能", "你得", "不应该熬夜", "你总是"],
    "ai_data_tone": ["系统检测到", "根据数据", "数据显示"]
  },

  "case_rules": {
    "A01": {
      "tool_calls_forbidden": ["get_health_data", "render_analysis_card", "send_feedback_card", "set_reminder"],
      "response_blacklist": ["睡眠建议", "早点睡", "睡眠质量", "建议你"],
      "response_max_sentences": 3
    },
    "A03": {
      "tool_calls_required": ["save_memory"],
      "response_blacklist": ["我记下了", "已记录", "我会记住", "已经记录"]
    },
    "A04": {
      "tool_calls_required": ["get_strategy"],
      "response_blacklist_refs": ["redline_coffee"],
      "response_blacklist": ["早起运动", "晨跑", "早上运动"],
      "response_must_not_be_list": true
    },
    "A05": {
      "tool_calls_required": ["get_health_data", "render_analysis_card"],
      "response_max_sentences": 4
    },
    "A06": {
      "response_blacklist_refs": ["ai_data_tone"],
      "response_max_sentences": 4
    },
    "A07": {
      "response_blacklist_refs": ["lecturing_tone"],
      "response_max_sentences": 3
    },
    "A08": {
      "tool_calls_required": ["save_memory"],
      "response_blacklist": ["太好了加油", "继续保持"]
    },
    "A09": {
      "tool_calls_required": ["save_memory"],
      "response_blacklist_refs": ["lecturing_tone"]
    },
    "A10": {
      "response_max_sentences": 3
    },
    "A12": {
      "response_blacklist_refs": ["redline_coffee"],
      "severity_override": "hard_fail"
    },
    "A14": {
      "response_blacklist": ["补觉是误区", "补觉没用", "补觉其实", "补觉并不能"]
    },
    "A15": {
      "response_blacklist": ["health_data_service_unavailable", "无法连接", "服务不可用", "接口报错"]
    },

    "B01": {
      "tool_calls_forbidden": ["get_health_data", "render_analysis_card", "send_feedback_card", "set_reminder"],
      "response_blacklist": ["建议你", "你应该", "试试"]
    },
    "B02": {
      "tool_calls_required": ["save_memory"],
      "tool_calls_forbidden": ["get_strategy", "send_feedback_card", "set_reminder"],
      "response_blacklist": ["建议你每晚", "设个提醒"]
    },

    "C07": {
      "response_blacklist_refs": ["lecturing_tone"]
    },

    "D01": {
      "response_blacklist": ["根据数据", "你的深睡", "建议你"],
      "response_max_sentences": 4
    },
    "D04": {
      "response_blacklist": ["你不应该", "你要振作", "别太自责"]
    },
    "D07": {
      "response_blacklist": ["午睡太多", "减少午睡", "不要午睡"],
      "severity_override": "hard_fail"
    }
  }
}
